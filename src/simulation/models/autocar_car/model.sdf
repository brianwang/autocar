<?xml version="1.0"?>
<sdf version="1.7">
  <model name="autocar_car">
    <static>false</static>

    <!-- Chassis -->
    <link name="chassis">
      <pose>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.00707</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01208</iyy>
          <iyz>0</iyz>
          <izz>0.01582</izz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry>
          <box>
            <size>0.25 0.18 0.10</size>
          </box>
        </geometry>
      </collision>
      <visual name="chassis_visual">
        <geometry>
          <box>
            <size>0.25 0.18 0.10</size>
          </box>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- Left Wheel -->
    <link name="left_wheel">
      <pose>-0.08 0.10 0 1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00003081</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00003081</iyy>
          <iyz>0</iyz>
          <izz>0.0000512</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.032</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.032</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- Right Wheel -->
    <link name="right_wheel">
      <pose>-0.08 -0.10 0 1.5708 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.00003081</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00003081</iyy>
          <iyz>0</iyz>
          <izz>0.0000512</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.032</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.032</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- Caster Wheel -->
    <link name="caster_wheel">
      <pose>0.10 0 0.01 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.0000009</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0000009</iyy>
          <iyz>0</iyz>
          <izz>0.0000009</izz>
        </inertia>
      </inertial>
      <collision name="caster_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.015</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="caster_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.015</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- LiDAR -->
    <link name="lidar_link">
      <pose>0.12 0 0.06 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry>
          <box>
            <size>0.03 0.03 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0 1 0 1</ambient>
          <diffuse>0 1 0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <sensor name="lidar_sensor" type="gpu_lidar">
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>6.283</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>12.0</max>
          </range>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>0.02</stddev>
          </noise>
        </lidar>
        <update_rate>10</update_rate>
        <topic>/model/autocar_car/scan</topic>
      </sensor>
    </link>

    <!-- IMU -->
    <link name="imu_link">
      <pose>0 0 0.03 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.000001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000001</iyy>
          <iyz>0</iyz>
          <izz>0.000001</izz>
        </inertia>
      </inertial>
      <visual name="imu_visual">
        <geometry>
          <box>
            <size>0.01 0.01 0.01</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
        </material>
      </visual>
      <sensor name="imu_sensor" type="imu">
        <imu>
          <angular_velocity>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </angular_velocity>
          <linear_acceleration>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </linear_acceleration>
        </imu>
        <update_rate>100</update_rate>
        <topic>/model/autocar_car/imu</topic>
      </sensor>
    </link>

    <!-- GPS -->
    <link name="gps_link">
      <pose>0 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.000001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000001</iyy>
          <iyz>0</iyz>
          <izz>0.000001</izz>
        </inertia>
      </inertial>
      <visual name="gps_visual">
        <geometry>
          <box>
            <size>0.01 0.01 0.01</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
        </material>
      </visual>
      <sensor name="gps_sensor" type="navsat">
        <navigation_satellite>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </navigation_satellite>
        <update_rate>10</update_rate>
        <topic>/model/autocar_car/gps</topic>
      </sensor>
    </link>

    <!-- Depth Camera -->
    <link name="depth_camera_link">
      <pose>0.12 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <visual name="depth_camera_visual">
        <geometry>
          <box>
            <size>0.02 0.02 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>1 1 0 1</ambient>
          <diffuse>1 1 0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <sensor name="depth_camera_sensor" type="depth_camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
        </camera>
        <update_rate>15</update_rate>
        <topic>/model/autocar_car/depth_image</topic>
      </sensor>
    </link>

    <!-- Joints -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <joint name="caster_wheel_joint" type="ball">
      <parent>chassis</parent>
      <child>caster_wheel</child>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>chassis</parent>
      <child>lidar_link</child>
    </joint>

    <joint name="imu_joint" type="fixed">
      <parent>chassis</parent>
      <child>imu_link</child>
    </joint>

    <joint name="gps_joint" type="fixed">
      <parent>chassis</parent>
      <child>gps_link</child>
    </joint>

    <joint name="depth_camera_joint" type="fixed">
      <parent>chassis</parent>
      <child>depth_camera_link</child>
    </joint>

    <!-- Plugins -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.20</wheel_separation>
      <wheel_radius>0.032</wheel_radius>
      <odom_publisher_frequency>50</odom_publisher_frequency>
      <topic>/model/autocar_car/cmd_vel</topic>
      <odom_topic>/model/autocar_car/odom</odom_topic>
      <tf_topic>/model/autocar_car/tf</tf_topic>
    </plugin>

  </model>
</sdf>
